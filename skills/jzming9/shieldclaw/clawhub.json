{
  "$schema": "https://clawhub.io/schemas/plugin-manifest.json",
  "id": "shieldclaw",
  "name": "ShieldClaw",
  "version": "1.1.0",
  "description": "OpenClaw 安全技能套件，提供安全扫描、实时防护、审计日志和敏感数据加密功能",
  "author": {
    "name": "ShieldClaw",
    "email": "support@shieldclaw.io",
    "url": "https://shieldclaw.io"
  },
  "license": "MIT",
  "homepage": "https://shieldclaw.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourname/shieldclaw"
  },
  "bugs": {
    "url": "https://github.com/yourname/shieldclaw/issues"
  },
  "keywords": [
    "security",
    "safety",
    "scan",
    "guard",
    "audit",
    "vault",
    "encryption",
    "privacy"
  ],
  "categories": [
    "security",
    "productivity"
  ],
  "icon": "./assets/icon.png",
  "screenshots": [
    "./assets/screenshot-1.png",
    "./assets/screenshot-2.png",
    "./assets/screenshot-3.png"
  ],
  "main": "./apps/openclaw-integration/dist/index.js",
  "entry": {
    "desktop": "./apps/openclaw-integration/dist/index.js",
    "web": "./apps/openclaw-integration/dist/web.js"
  },
  "engines": {
    "openclaw": ">=1.0.0"
  },
  "permissions": [
    "storage",
    "network",
    "filesystem"
  ],
  "activation": {
    "type": "clawhub-managed",
    "machineBinding": false,
    "maxActivations": 3
  },
  "update": {
    "autoUpdate": true,
    "updateUrl": "https://api.clawhub.io/v1/plugins/shieldclaw/updates"
  },
  "localization": {
    "default": "zh-CN",
    "supported": ["zh-CN", "en-US"]
  },
  "minAppVersion": "1.0.0",
  "targetSDKVersion": "1.0.0"
}
