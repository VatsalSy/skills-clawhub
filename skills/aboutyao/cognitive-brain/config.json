{
  "version": "5.3.11",
  "logging": {
    "level": "${LOG_LEVEL:-info}",
    "dir": "logs",
    "maxSize": "10MB",
    "maxFiles": 5,
    "console": {
      "enabled": true,
      "colorize": true
    },
    "file": {
      "enabled": true,
      "errorLog": "error.log",
      "combinedLog": "combined.log"
    }
  },
  "storage": {
    "primary": {
      "type": "postgresql",
      "host": "localhost",
      "port": 5432,
      "database": "cognitive_brain",
      "user": "postgres",
      "password": "${PGPASSWORD}",
      "poolSize": 10,
      "connectionTimeoutMillis": 5000,
      "queryTimeout": 10000,
      "extensions": ["pgvector", "pg_trgm"]
    },
    "cache": {
      "type": "redis",
      "host": "localhost",
      "port": 6379,
      "db": 0,
      "keyPrefix": "brain:"
    }
  },
  "embedding": {
    "provider": "local",
    "dimension": 384,
    "options": {
      "model": "paraphrase-multilingual-MiniLM-L12-v2",
      "script": "scripts/embed.py"
    }
  },
  "memory": {
    "sensory": {
      "ttl": 30000,
      "maxSize": 100,
      "storage": "redis"
    },
    "working": {
      "ttl": 3600000,
      "maxSize": 50,
      "storage": "redis"
    },
    "episodic": {
      "maxCount": 10000,
      "decayRate": 0.1,
      "storage": "postgresql"
    },
    "semantic": {
      "maxCount": 5000,
      "storage": "postgresql"
    }
  },
  "association": {
    "activationThreshold": 0.3,
    "decayFactor": 0.9,
    "maxDepth": 3,
    "cacheEnabled": true
  },
  "importance": {
    "enabled": true,
    "algorithm": "smart",
    "explicitIntent": {
      "highPatterns": ["记住", "重要", "保存", "记下来", "别忘了", "提醒我"],
      "lowPatterns": ["测试", "试试", "debug", "随便", "好奇", "问问"]
    },
    "factors": {
      "informationDensity": 0.25,
      "emotionIntensity": 0.20,
      "contentType": 0.25,
      "userIntent": 0.30
    },
    "default": 0.5
  },
  "forgetting": {
    "enabled": true,
    "schedule": "0 3 * * *",
    "minAge": 604800000,
    "importanceThreshold": 0.2,
    "typeRetention": {
      "test": { "days": 0.5, "maxImportance": 0.3, "autoDecay": true },
      "thought": { "days": 7, "maxImportance": 0.7 },
      "reflection": { "days": 14, "maxImportance": 0.8 },
      "conversation": { "days": 30, "maxImportance": 1.0 },
      "milestone": { "days": 365, "maxImportance": 1.0 }
    },
    "cleanupOrphans": true,
    "minAssociationCount": 1
  },
  "proactive": {
    "enabled": true,
    "maxSuggestions": 2,
    "confidenceThreshold": 0.5,
    "suggestionTypes": ["related_topic", "interest_followup", "expand_query"]
  },
  "autolearn": {
    "enabled": true,
    "reflection": {
      "schedule": "0 4 * * *",
      "lookbackHours": 24
    },
    "consolidation": {
      "schedule": "0 3 * * *",
      "similarityThreshold": 0.8
    },
    "patternMining": {
      "schedule": "0 5 * * 0",
      "minSupport": 5
    }
  },
  "selfaware": {
    "identity": {
      "type": "AI Agent",
      "name": "OpenClaw Agent",
      "runtime": "OpenClaw"
    },
    "reflectionInterval": 21600000,
    "confidenceThreshold": 0.7
  },
  "performance": {
    "cacheWarmupSize": 100,
    "maxRecallResults": 20,
    "indexOptimizationInterval": 86400000,
    "embedding": {
      "warmupOnStart": true,
      "warmupTimeout": 60000,
      "serveMode": false,
      "cacheEmbeddings": true
    }
  },
  "sharedWorkspace": {
    "enabled": true,
    "sync": true,
    "storage": {
      "type": "filesystem",
      "path": "~/.openclaw/workspace/shared"
    },
    "syncInterval": 30000,
    "conflictResolution": "newest-wins"
  },
  "safety": {
    "enabled": true,
    "strictMode": false,
    "blockedOperations": ["rm -rf", "format", "fdisk", "mkfs"],
    "requireConfirmation": ["delete_file", "send_email", "post_public"],
    "logPath": ".safety-log.json",
    "maxLogSize": 500
  }
}
